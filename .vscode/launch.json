{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Nest API",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    {
      "name": "Debug React Web",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web/src",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Debug API + Web",
      "configurations": ["Debug Nest API", "Debug React Web"]
    }
  ]
}