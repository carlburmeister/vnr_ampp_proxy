// Debug with Nginx servering front end pages
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Nest API",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true,
      "sourceMaps": true
    },
    {
      "name": "Debug React Web through Nginx",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8081",
      "webRoot": "${workspaceFolder}/web",
      "sourceMaps": true,
      "skipFiles": [
        "**/node_modules/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Debug API + Web",
      "configurations": [
        "Debug Nest API",
        "Debug React Web through Nginx"
      ]
    }
  ]
}